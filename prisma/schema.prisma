generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Planet {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  category     String
  status       String
  step         Int
  image        Json
  nextPlanetId String?  @db.ObjectId
  prevPlanetId String?  @db.ObjectId
  localized    Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("planets")
}