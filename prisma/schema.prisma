generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum PlanetStatus {
  draft
  published
}

enum PlanetCategory {
  common
  html
}

enum SupportedLanguage {
  az
  en
}

enum UserRole {
  USER
  ADMIN
}

// ---------- Composite Types ----------

type ImageMetadata {
  width  Int
  height Int
}

type LocalizedAlt {
  az String
  en String
}

type PlanetImage {
  url      String
  metadata ImageMetadata
  alt      LocalizedAlt
}

type PlanetTag {
  id  String
  tag String
}

// ---------- Models ----------

model Planet {
  id           String               @id @default(auto()) @map("_id") @db.ObjectId
  category     PlanetCategory
  status       PlanetStatus
  step         Int
  image        PlanetImage
  nextPlanetId String?              @db.ObjectId
  prevPlanetId String?              @db.ObjectId
  localized    PlanetLocalization[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@map("planets")
}

model PlanetLocalization {
  id             String            @id @default(auto()) @map("_id") @db.ObjectId
  lang           SupportedLanguage
  name           String
  tags           PlanetTag[]
  description    String
  researchTopics Json
  resources      Json?
  questions      Json
  contents       Json
  planetId       String            @db.ObjectId
  planet         Planet            @relation(fields: [planetId], references: [id], onDelete: Cascade)

  @@map("planet_localizations")
}

model User {
  id             String   @id @default(cuid()) @map("_id")
  email          String   @unique
  hashedPassword String
  firstName      String
  lastName       String
  role           UserRole @default(ADMIN)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("users")
}