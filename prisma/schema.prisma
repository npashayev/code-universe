generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Planet {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  category     String   // 'html' | 'css' | 'javascript'
  status       String   // 'draft' | 'published'
  step         Int
  image        Json     // { url: string, metadata: { width: number, height: number }, alt: { az: string, en: string } }
  nextPlanetId String?  @db.ObjectId
  prevPlanetId String?  @db.ObjectId
  localized    Json     // { en: LocalizedPlanetData, az: LocalizedPlanetData }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("planets")
}

